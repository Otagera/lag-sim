{
  "name": "lagos-governor-sim",
  "private": true,
  "scripts": {
    "dev": "concurrently --names client,server --prefix-colors cyan,yellow \"npm --prefix client run dev\" \"npm --prefix server run dev\"",
    "build": "npm --prefix client run build",
    "lint": "npm --prefix client run lint",
    "format": "npm --prefix client run format",
    "test": "npm --prefix client run test",
    "test:watch": "npm --prefix client run test:watch",
    "test:coverage": "npm --prefix client run test:coverage",
    "test:e2e": "npm --prefix client run test:e2e",
    "preview": "npm --prefix client run preview",
    "generate-types": "typeshare --lang=typescript --output-file=shared/types.ts server/src/types.rs"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
